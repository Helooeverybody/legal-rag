# Copy this file to `.env` and fill in the values you need.
# Only the keys for the provider(s) you actually use are required.
# Load order is handled automatically by python-dotenv at script startup.

# --- Google AI Studio (provider: aistudio) -----------------------------------
# Up to three keys can be set; the client rotates through them on failure/quota.
GOOGLE_API_KEY=
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=

# --- OpenRouter (provider: openrouter) ---------------------------------------
OPENROUTER_API_KEY=

# --- OpenAI (provider: openai) -----------------------------------------------
OPENAI_API_KEY=

# --- Optional tuning ---------------------------------------------------------
# Per-request timeout (seconds) for AI Studio generation calls. Default: 90
# LLM_REQUEST_TIMEOUT=90

# HuggingFace cache directory for embedding models. Defaults to ~/.cache/huggingface
# HF_HOME=/path/to/huggingface_cache
